<Window x:Class="Reclaim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Reclaim.App.ViewModels"
        xmlns:controls="clr-namespace:Reclaim.App.Controls"
        Title="Reclaim"
        Icon="Assets/reclaim.ico"
        Width="1180" Height="760"
        MinWidth="760" MinHeight="480"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border x:Name="RootBorder" Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- RC logo + wordmark (this area is draggable to move the window) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Width="28" Height="28" CornerRadius="6"
                            Background="{StaticResource AccentBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Cursor="Hand"
                            MouseLeftButtonDown="OnLogoClick"
                            ToolTip="Reclaim">
                        <TextBlock Text="RC" Foreground="#FF050507"
                                   FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Reclaim" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="15"
                               VerticalAlignment="Center" Margin="9,0,0,0" />

                    <!-- Administrator badge: shown only when elevated -->
                    <Border CornerRadius="4" Padding="7,2" Margin="10,0,0,0"
                            VerticalAlignment="Center" Background="{StaticResource ErrorBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Reclaim is running with administrator rights and can read protected folders. Take extra care with deletion."
                            Visibility="{Binding IsElevated, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="#FF1A1206" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="Administrator" Foreground="#FF1A1206"
                                       FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Restart-as-admin: shown only when NOT elevated -->
                    <Button Content="Restart as admin" Margin="10,0,0,0" Padding="9,3"
                            Command="{Binding RestartAsAdminCommand}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Relaunch with administrator rights to scan protected system folders"
                            Visibility="{Binding IsElevated, Converter={StaticResource InverseBoolToVis}}" />
                </StackPanel>

                <!-- Storage / Cleanup mode toggle -->
                <Border Grid.Column="1" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="5" Padding="2" Margin="0,0,12,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Storage" Command="{Binding StorageModeCommand}"
                                Padding="12,4" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStorageMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cleanup" Command="{Binding CleanupModeCommand}"
                                Padding="12,4" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCleanupMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBox Grid.Column="2"
                         Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

                <Button Grid.Column="3" Content="Browse…" Margin="8,0,0,0"
                        Click="OnBrowseClick"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

                <Button Grid.Column="4" Content="Scan" Margin="8,0,0,0"
                        Style="{StaticResource AccentButton}" MinWidth="80"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Command="{Binding ScanCommand}" />

                <Button Grid.Column="5" Content="Cancel" Margin="8,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Command="{Binding CancelCommand}" />

                <Button Grid.Column="6" Content="Export…" Margin="8,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Export the current scan to CSV or JSON"
                        Command="{Binding ExportScanCommand}" />

                <!-- Window controls (custom, since native caption buttons are off) -->
                <StackPanel Grid.Column="7" Orientation="Horizontal"
                            Margin="14,0,0,0" VerticalAlignment="Top"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE713;" Click="OnSettings" Style="{StaticResource WindowButton}"
                            ToolTip="Settings" />
                    <Button Content="&#xE921;" Click="OnMinimize" Style="{StaticResource WindowButton}"
                            ToolTip="Minimize" />
                    <Button x:Name="MaxButton" Content="&#xE922;" Click="OnMaximizeRestore"
                            Style="{StaticResource WindowButton}" ToolTip="Maximize" />
                    <Button Content="&#xE8BB;" Click="OnClose" Style="{StaticResource WindowCloseButton}"
                            ToolTip="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Storage mode content: tree | treemap ===== -->
        <Grid Grid.Row="1" Visibility="{Binding IsStorageMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="260" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            <TreeView Grid.Row="0" ItemsSource="{Binding RootItems}"
                      SelectedItemChanged="OnTreeSelectionChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Grid ToolTip="{Binding Tooltip}" Margin="0,1"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open"
                                                  Command="{Binding PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                        <Separator Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                        <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"
                                              Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                    <MenuItem Header="Delete contents"
                                              Command="{Binding PlacementTarget.Tag.DeleteContentsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"
                                              Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                    <MenuItem Header="Delete folder…"
                                              Command="{Binding PlacementTarget.Tag.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"
                                              Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="44" />
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Source="{Binding Icon}"
                                   Width="16" Height="16"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HadError}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Column="2" Height="6" Width="{Binding BarWidth}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Background="{Binding BarBrush}" CornerRadius="3"
                                    Opacity="0.75" Margin="4,0" />

                            <TextBlock Grid.Column="3" Text="{Binding SizeText}"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" />

                            <TextBlock Grid.Column="4" Text="{Binding PercentText}"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="6,0,4,0" />
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

                <!-- "What is this?" info panel for the selected item -->
                <Border Grid.Row="1" Background="{StaticResource PanelRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="12,10" MaxHeight="320"
                        Visibility="{Binding HasSelectedInfo, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding SelectedInfo.Title}"
                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                       FontSize="13" TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1" CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="{Binding SelectedInfo.Safety, Converter={StaticResource SafetyToBrush}}">
                                <TextBlock Text="{Binding SelectedInfo.Safety, Converter={StaticResource SafetyToLabel}}"
                                           FontSize="10" Foreground="#FF0A0A0A" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding SelectedName}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="10.5" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SelectedInfo.Description}" Foreground="{StaticResource TextBrush}"
                                   FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Created by" FontSize="10.5"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,12,2" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedInfo.CreatedBy}"
                                       FontSize="10.5" Foreground="{StaticResource TextBrush}" Margin="0,0,0,2"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Typical size" FontSize="10.5"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,12,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedInfo.TypicalSize}"
                                       FontSize="10.5" Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock Text="{Binding SelectedInfo.SafetyNote}" FontSize="11"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"
                                   TextWrapping="Wrap" />

                        <!-- Scrollable preview of the file's text contents (text files only) -->
                        <StackPanel Margin="0,10,0,0"
                                    Visibility="{Binding HasSelectedPreview, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Preview" FontSize="10.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4" />
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" MaxHeight="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="6,4">
                                    <TextBlock Text="{Binding SelectedPreview}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="Consolas, monospace" FontSize="11"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- View switcher + contextual controls -->
                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Treemap | Largest items toggle -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="Treemap" Command="{Binding ShowTreemapCommand}"
                                    Padding="10,3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTreemapView}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="List view" Command="{Binding ShowLargestCommand}"
                                    Padding="10,3" Margin="6,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLargestView}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Treemap controls: Up + min-size slider (scales with width) -->
                        <Grid Grid.Column="1" Grid.ColumnSpan="2" Margin="12,0,0,0"
                              Visibility="{Binding IsTreemapView, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="← Back" Padding="8,3"
                                    Command="{Binding TreemapUpCommand}" />
                            <TextBlock Grid.Column="1" Text="{Binding MinSizeLabel}"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" Margin="14,0,8,0" FontSize="11"
                                       MinWidth="150" />
                            <Slider x:Name="MinSizeSlider" Grid.Column="2"
                                    Minimum="0" Maximum="{Binding MaxSizeTier}"
                                    Value="{Binding MinSizeTier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    IsMoveToPointEnabled="True"
                                    Thumb.DragStarted="OnSliderDragStarted"
                                    Thumb.DragCompleted="OnSliderCommit"
                                    ValueChanged="OnSliderValueChanged"
                                    ToolTip="Drag to hide small files and declutter the map" />
                        </Grid>

                        <!-- Largest-items controls: Files | Folders -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0"
                                    Visibility="{Binding IsLargestView, Converter={StaticResource BoolToVis}}">
                            <Button Content="Files" Command="{Binding ShowFilesCommand}" Padding="10,3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFilesKind}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Folders" Command="{Binding ShowFoldersCommand}"
                                    Padding="10,3" Margin="6,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFoldersKind}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Shared breadcrumb: reflects the focus folder for both views -->
                <Border Grid.Row="1" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4" Visibility="{Binding HasFocus, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Breadcrumb}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding Label}" Style="{StaticResource BreadcrumbSegment}"
                                            Click="OnBreadcrumbClick" />
                                    <TextBlock Text="›" Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center" Margin="2,0"
                                               Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Treemap -->
                <controls:TreemapControl x:Name="Treemap" Grid.Row="2"
                                         RootNode="{Binding TreemapRoot}"
                                         MinFileBytes="{Binding MinFileBytes}"
                                         LabelMode="BigBlocks"
                                         Visibility="{Binding IsTreemapView, Converter={StaticResource BoolToVis}}" />

                <!-- Largest items list -->
                <DataGrid Grid.Row="2"
                          Visibility="{Binding IsLargestView, Converter={StaticResource BoolToVis}}"
                          ItemsSource="{Binding FlatItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          Background="{StaticResource PanelBrush}"
                          RowBackground="{StaticResource PanelBrush}"
                          AlternatingRowBackground="{StaticResource PanelRaisedBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0" CanUserAddRows="False"
                          EnableRowVirtualization="True"
                          SelectionChanged="OnFlatItemSelected"
                          MouseDoubleClick="OnFlatItemDoubleClick">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Tag"
                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Open"
                                                  Command="{Binding PlacementTarget.Tag.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                        <Separator Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                        <MenuItem Header="Delete"
                                                  Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVis}}" />
                                        <MenuItem Header="Delete contents"
                                                  Command="{Binding PlacementTarget.Tag.DeleteContentsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="Delete folder…"
                                                  Command="{Binding PlacementTarget.Tag.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="2*" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90"
                                            SortMemberPath="SizeBytes">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="3*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ===== Cleanup mode content: categories | treemap highlight ===== -->
        <Grid Grid.Row="1" Visibility="{Binding IsCleanupMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Category list with expandable findings -->
            <Grid Grid.Column="0" Background="{StaticResource PanelBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PanelRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="Reclaimable space" Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="{Binding CleanupSummary}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap" />
                        <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="10.5"
                                   Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="Select items to clean. Safe items go to the Recycle Bin by default. System items that need Windows tools (DISM, Disk Cleanup) are listed but cannot be removed here." />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Duplicate files section (collapsible) -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="Duplicate files" Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold" FontSize="13" />
                            </Expander.Header>
                            <StackPanel Margin="10,8,10,10">
                                <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="Scans the files from your last scan for identical copies (same content, byte for byte). You can then keep one of each and send the extra copies to the Recycle Bin." />
                                <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="10.5"
                                           Margin="0,6,0,0" TextWrapping="Wrap"
                                           Text="{Binding DuplicatesHint}" />
                                <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="10.5"
                                           Margin="0,6,0,0" TextWrapping="Wrap"
                                           Text="{Binding DuplicateScopeText}" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Scan for duplicate files" Padding="12,5"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding FindDuplicatesCommand}" />
                                    <Button Content="Limit to folder…" Padding="10,5" Margin="8,0,0,0"
                                            Command="{Binding ChooseDuplicateScopeCommand}"
                                            ToolTip="Restrict the duplicate scan to one folder (faster on big drives)" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Recycle Bin section (collapsible) -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Recycle Bin" Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding RecycleBinText}" Foreground="{StaticResource TextDimBrush}"
                                               FontSize="10.5" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="10,8,10,10">
                                <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="Deleted files sit in the Recycle Bin until it's emptied, still taking up space. Emptying it frees that space permanently." />
                                <Button Content="Empty Recycle Bin" Margin="0,10,0,0"
                                        HorizontalAlignment="Left" Padding="12,5"
                                        Command="{Binding EmptyRecycleBinCommand}" />
                            </StackPanel>
                        </Expander>

                        <!-- Large & old files section (collapsible) -->
                        <Expander Margin="0,0,0,8" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="Large &amp; old files" Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold" FontSize="13" />
                            </Expander.Header>
                            <StackPanel Margin="10,8,10,10">
                                <TextBlock Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="Finds big files you haven't changed in a long time — often forgotten downloads, old videos, or stale backups worth reviewing." />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Larger than (MB):"
                                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                             Text="{Binding LargeOldMinSizeMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Older than (months):"
                                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Text="{Binding LargeOldMinMonths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Button Content="Find large, old files" Margin="0,10,0,0"
                                        HorizontalAlignment="Left" Padding="12,5"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding FindLargeOldCommand}" />
                            </StackPanel>
                        </Expander>

                        <ItemsControl ItemsSource="{Binding CleanupCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,0,0,6" Background="{StaticResource PanelRaisedBrush}">
                                    <Expander.Header>
                                        <Grid Margin="2,2,8,2" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                                      IsChecked="{Binding SelectAll, Mode=TwoWay}"
                                                      Visibility="{Binding HasDeletable, Converter={StaticResource BoolToVis}}"
                                                      ToolTip="Select all cleanable items in this category" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CountText}" Foreground="{StaticResource TextDimBrush}"
                                                           FontSize="10.5" />
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="3" Padding="6,2" Margin="8,0"
                                                    VerticalAlignment="Center" Background="{Binding SafetyBrush}">
                                                <TextBlock Text="{Binding SafetyLabel}" FontSize="10"
                                                           Foreground="#FF0A0A0A" FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding SizeText}"
                                                       Foreground="{StaticResource AccentBrush}" FontWeight="Bold"
                                                       VerticalAlignment="Center" MinWidth="70" TextAlignment="Right" />
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Findings}" Margin="8,4,4,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource PanelBrush}" CornerRadius="4"
                                                        Padding="10" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" VerticalAlignment="Top"
                                                                  Margin="0,2,10,0"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  IsEnabled="{Binding IsDeletable}"
                                                                  Visibility="{Binding IsDeletable, Converter={StaticResource BoolToVis}}"
                                                                  ToolTip="Select to clean this location" />
                                                        <StackPanel Grid.Column="1"
                                                                    MouseLeftButtonUp="OnFindingClick" Cursor="Hand">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                                           Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1" Text="{Binding SizeText}"
                                                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                            </Grid>
                                                            <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextDimBrush}"
                                                                       FontSize="10.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Explanation}" Foreground="{StaticResource TextDimBrush}"
                                                                       FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding ActionHint}" Foreground="{StaticResource ErrorBrush}"
                                                                       FontSize="10.5" FontStyle="Italic" Margin="0,5,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Visibility="{Binding IsDeletable, Converter={StaticResource InverseBoolToVis}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Clean action bar -->
                <Border Grid.Row="2" Background="{StaticResource PanelRaisedBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding PermanentDelete, Mode=TwoWay}"
                                  Foreground="{StaticResource TextDimBrush}"
                                  Content="Delete permanently (skip Recycle Bin)"
                                  ToolTip="When off, items go to the Recycle Bin and can be restored." />
                        <Button Grid.Column="1" Style="{StaticResource AccentButton}"
                                Content="{Binding CleanButtonText}" MinWidth="160" Padding="14,7"
                                Command="{Binding CleanSelectedCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" />

            <!-- Right side: same Treemap/List switcher + breadcrumb as Storage,
                 sharing the VM's focus so both modes navigate identically. -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="Treemap" Command="{Binding ShowTreemapCommand}" Padding="10,3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTreemapView}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="List view" Command="{Binding ShowLargestCommand}"
                                    Padding="10,3" Margin="6,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLargestView}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Declutter slider, shown in treemap view (same as Storage) -->
                        <Grid Grid.Column="1" Margin="14,0,0,0"
                              Visibility="{Binding IsTreemapView, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding MinSizeLabel}"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                                       MinWidth="150" />
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="{Binding MaxSizeTier}"
                                    Value="{Binding MinSizeTier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    IsMoveToPointEnabled="True"
                                    Thumb.DragStarted="OnSliderDragStarted"
                                    Thumb.DragCompleted="OnSliderCommit"
                                    ValueChanged="OnSliderValueChanged"
                                    ToolTip="Drag to hide small files and declutter the map" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Shared breadcrumb -->
                <Border Grid.Row="1" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,4" Visibility="{Binding HasFocus, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Breadcrumb}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{Binding Label}" Style="{StaticResource BreadcrumbSegment}"
                                            Click="OnBreadcrumbClick" />
                                    <TextBlock Text="›" Foreground="{StaticResource TextDimBrush}"
                                               VerticalAlignment="Center" Margin="2,0"
                                               Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Treemap -->
                <controls:TreemapControl Grid.Row="2" RootNode="{Binding TreemapRoot}"
                                         MinFileBytes="{Binding MinFileBytes}"
                                         LabelMode="BigBlocks"
                                         Visibility="{Binding IsTreemapView, Converter={StaticResource BoolToVis}}" />

                <!-- List view with reclaimable flag column -->
                <DataGrid Grid.Row="2"
                          Visibility="{Binding IsLargestView, Converter={StaticResource BoolToVis}}"
                          ItemsSource="{Binding FlatItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          Background="{StaticResource PanelBrush}"
                          RowBackground="{StaticResource PanelBrush}"
                          AlternatingRowBackground="{StaticResource PanelRaisedBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0" CanUserAddRows="False"
                          EnableRowVirtualization="True"
                          MouseDoubleClick="OnFlatItemDoubleClick">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Tag"
                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Clean this file"
                                                  Command="{Binding PlacementTarget.Tag.CleanThisFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding CanCleanThis, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="(Not a reclaimable file)" IsEnabled="False"
                                                  Visibility="{Binding CanCleanThis, Converter={StaticResource InverseBoolToVis}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="2*" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Reclaimable" Width="130" SortMemberPath="IsReclaimable">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Background="{Binding ReclaimableBrush}"
                                            ToolTip="{Binding ReclaimableTooltip}"
                                            Visibility="{Binding IsReclaimable, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding ReclaimableLabel}" FontSize="10"
                                                   Foreground="#FF0A0A0A" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90"
                                            SortMemberPath="SizeBytes">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,7">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Progress bar row (only while a long operation runs) -->
                <Grid Grid.Row="0" Margin="0,0,0,5"
                      Visibility="{Binding ProgressActive, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Height="6"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding ProgressIndeterminate}"
                                 Background="{StaticResource PanelRaisedBrush}"
                                 Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextDimBrush}"
                               Text="{Binding ProgressValue, StringFormat={}{0:0}%}"
                               Visibility="{Binding ProgressIndeterminate, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                               Foreground="{StaticResource TextDimBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" Text="{Binding SummaryText}"
                               Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                               Margin="16,0,0,0" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
